# Copy this file to .env and fill in your values.
# .env is gitignored and never committed.

# LLM backend: "huggingface" or "anthropic"
LLM_PROVIDER=huggingface

# HuggingFace (used when LLM_PROVIDER=huggingface)
HF_API_TOKEN=hf_your_token_here
HF_MODEL=Qwen/Qwen2.5-72B-Instruct

# Anthropic (used when LLM_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=sk-ant-your_key_here
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Flask server
PORT=5000
FLASK_DEBUG=false

# CORS: set to your frontend origin in production (e.g. https://yoursite.netlify.app)
# Leave as * for local development
ALLOWED_ORIGIN=*
